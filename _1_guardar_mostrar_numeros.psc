Proceso guardar_mostrar_numeros
	Dimension numeros[5];
	Definir i Como Entero;
	Para i<-1 Hasta 5 Con Paso 1 Hacer
		Escribir "Ingrese un numero ";
		Leer numeros[i];
	FinPara
	Escribir "Los numeros ingresados son:";
	Para i<-1 Hasta 5 Con Paso 1 Hacer
		Escribir numeros[i];
	FinPara
FinProceso